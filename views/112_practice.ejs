<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>112 신고연습</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "Malgun Gothic", "맑은 고딕", sans-serif;
      background: linear-gradient(180deg, #07162c 0%, #0c2445 48%, #102f59 100%);
      color: #f4f8ff;
    }

    a { text-decoration: none; color: inherit; }

    .page {
      max-width: 460px;
      min-height: 100vh;
      margin: 0 auto;
      padding: 18px 14px 28px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
      color: rgba(255,255,255,0.92);
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 38px;
      padding: 0 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.10);
      backdrop-filter: blur(6px);
      font-size: 14px;
      font-weight: 700;
      border: 1px solid rgba(255,255,255,0.12);
    }

    .status-text {
      font-size: 13px;
      color: rgba(255,255,255,0.72);
      font-weight: 700;
    }

    .practice-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 14px;
    }

    .tab-btn {
      height: 44px;
      border: none;
      border-radius: 14px;
      background: rgba(255,255,255,0.10);
      color: #fff;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.10);
    }

    .tab-btn.active {
      background: linear-gradient(135deg, #2b85ff, #125ed0);
    }

    .tab-panel {
      display: none;
    }

    .tab-panel.active {
      display: block;
    }

    .card {
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.10);
      box-shadow: 0 20px 50px rgba(0,0,0,0.22);
      border-radius: 28px;
      padding: 22px 18px;
      backdrop-filter: blur(10px);
    }

    .hero-title {
      margin: 0 0 10px;
      font-size: 30px;
      line-height: 1.25;
      font-weight: 900;
      letter-spacing: -0.8px;
    }

    .hero-desc {
      margin: 0;
      font-size: 15px;
      line-height: 1.65;
      color: rgba(255,255,255,0.88);
      word-break: keep-all;
    }

    .notice {
      margin-top: 14px;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(255,255,255,0.10);
      font-size: 14px;
      line-height: 1.6;
      color: #dfeaff;
    }

    .section-title {
      margin: 20px 0 12px;
      font-size: 20px;
      font-weight: 900;
      color: #fff;
    }

    .step-list {
      display: grid;
      gap: 12px;
    }

    .step {
      border-radius: 18px;
      background: rgba(255,255,255,0.08);
      padding: 14px;
      border: 1px solid rgba(255,255,255,0.08);
    }

    .step-num {
      display: inline-flex;
      width: 30px;
      height: 30px;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: #1565c0;
      color: #fff;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .step strong {
      display: block;
      margin-bottom: 6px;
      font-size: 16px;
      color: #fff;
    }

    .step p,
    .scenario-text,
    .guide-text {
      margin: 0;
      color: rgba(255,255,255,0.82);
      font-size: 14px;
      line-height: 1.65;
      word-break: keep-all;
    }

    .scenario-box {
      border-radius: 18px;
      padding: 15px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.08);
      margin-top: 12px;
    }

    .scenario-title {
      font-size: 16px;
      font-weight: 900;
      margin-bottom: 8px;
      color: #8cc2ff;
    }

    .scenario-type-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-bottom: 14px;
    }

    .phone-screen {
      position: relative;
      overflow: hidden;
      border-radius: 34px;
      padding: 22px 18px 24px;
      background: linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.05));
      border: 1px solid rgba(255,255,255,0.10);
      box-shadow: 0 20px 50px rgba(0,0,0,0.34);
      min-height: 760px;
      backdrop-filter: blur(10px);
    }

    .phone-screen::before {
      content: "";
      position: absolute;
      top: -90px;
      right: -60px;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: rgba(46, 134, 255, 0.18);
      filter: blur(10px);
    }

    .phone-screen::after {
      content: "";
      position: absolute;
      bottom: -70px;
      left: -45px;
      width: 190px;
      height: 190px;
      border-radius: 50%;
      background: rgba(13, 78, 184, 0.16);
      filter: blur(8px);
    }

    .dynamic-island {
      width: 126px;
      height: 28px;
      margin: 0 auto 18px;
      border-radius: 999px;
      background: rgba(0,0,0,0.58);
      border: 1px solid rgba(255,255,255,0.06);
    }

    .call-header {
      position: relative;
      z-index: 1;
      text-align: center;
      margin-top: 6px;
    }

    .call-status {
      font-size: 14px;
      font-weight: 800;
      color: #8cc2ff;
      letter-spacing: 0.3px;
      margin-bottom: 8px;
    }

    .call-name {
      font-size: 34px;
      line-height: 1.2;
      font-weight: 900;
      letter-spacing: -0.8px;
      margin-bottom: 6px;
    }

    .call-sub {
      font-size: 15px;
      line-height: 1.55;
      color: rgba(255,255,255,0.78);
      word-break: keep-all;
      max-width: 320px;
      margin: 0 auto;
    }

    .avatar-wrap {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      margin: 24px 0 20px;
    }

    .avatar-ring {
      position: relative;
      width: 132px;
      height: 132px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(circle, rgba(255,255,255,0.30), rgba(255,255,255,0.08));
      box-shadow: 0 0 0 12px rgba(255,255,255,0.05), 0 0 0 24px rgba(255,255,255,0.03);
      animation: pulseRing 2s infinite;
    }

    .avatar-inner {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, #1f6fe5, #0c4aa3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.25);
    }

    @keyframes pulseRing {
      0% { transform: scale(1); }
      50% { transform: scale(1.03); }
      100% { transform: scale(1); }
    }

    .wave-row {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: center;
      align-items: flex-end;
      gap: 6px;
      height: 44px;
      margin-bottom: 18px;
    }

    .wave-bar {
      width: 7px;
      border-radius: 999px;
      background: linear-gradient(180deg, #8bc6ff, #2f87ff);
      animation: wave 1s ease-in-out infinite;
      opacity: 0.95;
    }

    .wave-bar:nth-child(1) { height: 12px; animation-delay: 0s; }
    .wave-bar:nth-child(2) { height: 26px; animation-delay: 0.15s; }
    .wave-bar:nth-child(3) { height: 34px; animation-delay: 0.3s; }
    .wave-bar:nth-child(4) { height: 18px; animation-delay: 0.45s; }
    .wave-bar:nth-child(5) { height: 30px; animation-delay: 0.2s; }
    .wave-bar:nth-child(6) { height: 14px; animation-delay: 0.35s; }

    @keyframes wave {
      0%, 100% { transform: scaleY(0.65); opacity: 0.6; }
      50% { transform: scaleY(1.15); opacity: 1; }
    }

    .question-card {
      position: relative;
      z-index: 1;
      padding: 18px 16px;
      border-radius: 24px;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
      margin-bottom: 14px;
    }

    .question-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 12px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 74px;
      height: 30px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(140,194,255,0.18);
      color: #d9ebff;
      font-size: 12px;
      font-weight: 800;
    }

    .replay-btn {
      border: none;
      background: rgba(255,255,255,0.12);
      color: #fff;
      height: 34px;
      padding: 0 12px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.10);
    }

    .question-text {
      font-size: 22px;
      line-height: 1.45;
      font-weight: 800;
      color: #ffffff;
      word-break: keep-all;
      letter-spacing: -0.4px;
    }

    .hint-box {
      position: relative;
      z-index: 1;
      border-radius: 20px;
      padding: 14px 14px;
      background: rgba(10, 24, 48, 0.40);
      border: 1px solid rgba(255,255,255,0.08);
      margin-bottom: 16px;
    }

    .hint-title {
      font-size: 13px;
      font-weight: 900;
      color: #8cc2ff;
      margin-bottom: 8px;
    }

    .hint-text {
      margin: 0;
      color: rgba(255,255,255,0.82);
      font-size: 14px;
      line-height: 1.6;
      word-break: keep-all;
    }

    .answer-buttons {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 12px;
    }

    .answer-btn {
      width: 100%;
      min-height: 64px;
      border: none;
      border-radius: 20px;
      padding: 14px 16px;
      background: rgba(255,255,255,0.13);
      color: #fff;
      text-align: left;
      font-size: 15px;
      line-height: 1.55;
      font-weight: 700;
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 10px 18px rgba(0,0,0,0.14);
      transition: transform 0.16s ease, background 0.16s ease, border-color 0.16s ease;
    }

    .answer-btn:hover,
    .answer-btn:active {
      transform: translateY(-1px);
      background: rgba(255,255,255,0.18);
      border-color: rgba(255,255,255,0.18);
    }

    .feedback-box {
      display: none;
      position: relative;
      z-index: 1;
      margin-top: 14px;
      padding: 14px;
      border-radius: 18px;
      font-size: 14px;
      line-height: 1.6;
      font-weight: 700;
    }

    .feedback-good {
      background: rgba(46, 160, 82, 0.20);
      border: 1px solid rgba(83, 220, 131, 0.26);
      color: #dfffe9;
    }

    .feedback-bad {
      background: rgba(214, 59, 53, 0.20);
      border: 1px solid rgba(255, 126, 120, 0.24);
      color: #ffe5e3;
    }

    .call-actions {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-top: 20px;
      margin-bottom: 22px;
    }

    .call-icon-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      color: rgba(255,255,255,0.88);
      font-size: 12px;
      font-weight: 700;
    }

    .call-icon {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.10);
      font-size: 24px;
    }

    .bottom-controls {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 18px;
      margin-top: auto;
      padding-top: 6px;
    }

    .control-btn {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      box-shadow: 0 10px 22px rgba(0,0,0,0.22);
    }

    .control-btn.secondary {
      background: rgba(255,255,255,0.14);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.10);
    }

    .control-btn.danger {
      background: linear-gradient(135deg, #f05454, #d93535);
      color: #fff;
    }

    .result-box {
      display: none;
      position: relative;
      z-index: 1;
      border-radius: 24px;
      padding: 20px 18px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.14);
      text-align: center;
      margin-top: 10px;
    }

    .result-title {
      font-size: 24px;
      font-weight: 900;
      margin-bottom: 10px;
      color: #ffffff;
    }

    .result-text {
      margin: 0;
      font-size: 15px;
      line-height: 1.7;
      color: rgba(255,255,255,0.88);
      word-break: keep-all;
    }

    .result-actions {
      display: grid;
      gap: 10px;
      margin-top: 16px;
    }

    .result-action-btn {
      height: 48px;
      border: none;
      border-radius: 16px;
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
    }

    .result-primary {
      background: linear-gradient(135deg, #2b85ff, #125ed0);
      color: #fff;
    }

    .result-secondary {
      background: rgba(255,255,255,0.12);
      color: #fff;
      border: 1px solid rgba(255,255,255,0.12);
    }

    .foot-note {
      margin-top: 16px;
      text-align: center;
      font-size: 12px;
      color: rgba(255,255,255,0.58);
      line-height: 1.6;
      word-break: keep-all;
    }

    @media (max-width: 420px) {
      .page { padding: 14px 12px 24px; }
      .phone-screen { border-radius: 28px; padding: 18px 14px 22px; }
      .call-name { font-size: 30px; }
      .question-text { font-size: 20px; }
      .answer-btn { font-size: 14px; }
      .call-actions { gap: 10px; }
      .call-icon { width: 52px; height: 52px; font-size: 22px; }
      .practice-tabs,
      .scenario-type-tabs {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="topbar">
      <a href="/" class="back-btn">← 홈으로</a>
      <div class="status-text">112 신고연습</div>
    </div>

    <div class="practice-tabs">
      <button class="tab-btn active" onclick="showTab('scenario')">1. 시나리오 보기</button>
      <button class="tab-btn" onclick="showTab('voice')">2. 음성 체험하기</button>
    </div>

    <div id="scenarioTab" class="tab-panel active">
      <div class="card">
        <h1 class="hero-title">112 신고연습</h1>
        <p class="hero-desc">
          실제 신고 전, 어떤 내용을 말하면 되는지 미리 연습해보는 화면입니다.
          침착하게 위치, 상황, 위험 여부를 전달하는 연습을 해보세요.
        </p>

        <div class="notice">
          본 페이지는 교육·연습용 예시입니다. 실제 위험 상황에서는 지체하지 말고 즉시 112에 신고하세요.
        </div>

        <h2 class="section-title">신고할 때 꼭 말해야 하는 3가지</h2>
        <div class="step-list">
          <div class="step">
            <span class="step-num">1</span>
            <strong>어디인지</strong>
            <p>현재 위치, 주소, 건물명, 주변 큰 표지물 등을 먼저 말합니다.</p>
          </div>
          <div class="step">
            <span class="step-num">2</span>
            <strong>무슨 일인지</strong>
            <p>절도, 폭행, 보이스피싱 의심, 교통사고 등 상황을 짧고 분명하게 말합니다.</p>
          </div>
          <div class="step">
            <span class="step-num">3</span>
            <strong>지금 얼마나 위험한지</strong>
            <p>가해자 유무, 금전 요구 여부, 다친 사람 여부, 도주 방향 등을 알려줍니다.</p>
          </div>
        </div>

        <h2 class="section-title">112 신고 예시</h2>
        <div class="scenario-box">
          <div class="scenario-title">상황 예시</div>
          <p class="scenario-text">
            밤길에 귀가하던 중, 한 남성이 앞사람의 가방을 빼앗아 도망가는 장면을 목격했습니다.
            주변에는 편의점이 있고, 도주 방향은 버스정류장 쪽입니다.
          </p>
        </div>

        <div class="scenario-box">
          <div class="scenario-title">예시 답변</div>
          <p class="guide-text">
            “무안읍 ○○편의점 앞입니다. 방금 한 남성이 여성 가방을 빼앗고 버스정류장 방향으로 도망갔습니다.
            피해자는 넘어진 상태입니다.”
          </p>
        </div>

        <h2 class="section-title">보이스피싱 신고 예시</h2>
        <div class="scenario-box">
          <div class="scenario-title">상황 예시</div>
          <p class="scenario-text">
            검찰을 사칭한 사람이 전화로 “계좌가 범죄에 연루됐다”고 말하며
            안전계좌로 돈을 보내라고 요구하고, 휴대폰 앱 설치도 유도했습니다.
          </p>
        </div>

        <div class="scenario-box">
          <div class="scenario-title">예시 답변</div>
          <p class="guide-text">
            “검찰을 사칭한 전화가 왔고, 제 계좌가 범죄에 연루됐다며 돈을 보내라고 했습니다.
            휴대폰 앱 설치도 요구했습니다. 그랬더니 알수없는 휴대폰이 개통되었어요 .”
          </p>
        </div>
      </div>
    </div>

    <div id="voiceTab" class="tab-panel">
      <div class="scenario-type-tabs">
        <button class="tab-btn active" id="scenarioTheftBtn" onclick="changeScenario('theft')">절도 신고</button>
        <button class="tab-btn" id="scenarioPhishingBtn" onclick="changeScenario('phishing')">보이스피싱 신고</button>
      </div>

      <div class="phone-screen">
        <div class="dynamic-island"></div>

        <div class="call-header">
          <div class="call-status" id="callStatus">112 연결됨</div>
          <div class="call-name">112</div>
          <div class="call-sub">실제 신고 전, 접수요원의 질문에 어떻게 답하면 좋은지 전화처럼 연습해보세요.</div>
        </div>

        <div class="avatar-wrap">
          <div class="avatar-ring">
            <div class="avatar-inner">👮</div>
          </div>
        </div>

        <div class="wave-row" id="waveRow">
          <div class="wave-bar"></div>
          <div class="wave-bar"></div>
          <div class="wave-bar"></div>
          <div class="wave-bar"></div>
          <div class="wave-bar"></div>
          <div class="wave-bar"></div>
        </div>

        <div class="question-card" id="quizBox">
          <div class="question-top">
            <div class="badge" id="questionTitle">질문 1</div>
            <button class="replay-btn" onclick="replayCurrentAudio()">🔊 듣기</button>
          </div>
          <div class="question-text" id="questionText"></div>
        </div>

        <div class="hint-box" id="hintBox">
          <div class="hint-title">신고 팁</div>
          <p class="hint-text" id="hintText"></p>
        </div>

        <div class="answer-buttons" id="answerButtons"></div>
        <div class="feedback-box" id="feedbackBox"></div>

        <div class="result-box" id="resultBox">
          <div class="result-title">연습 완료</div>
          <p class="result-text" id="resultText"></p>
          <div class="result-actions">
            <button class="result-action-btn result-primary" onclick="restartPractice()">다시 연습하기</button>
            <button class="result-action-btn result-secondary" onclick="goHome()">홈으로</button>
          </div>
        </div>

        <div class="foot-note">
          본 페이지는 교육용입니다. 실제 위급 상황에서는 지체하지 말고 즉시 112에 신고하세요.
        </div>
      </div>
    </div>
  </div>

  <audio id="audioPlayer"></audio>

  <script>
    function showTab(tabName) {
      const scenarioTab = document.getElementById("scenarioTab");
      const voiceTab = document.getElementById("voiceTab");
      const buttons = document.querySelectorAll(".practice-tabs .tab-btn");

      scenarioTab.classList.remove("active");
      voiceTab.classList.remove("active");
      buttons.forEach(btn => btn.classList.remove("active"));

      if (tabName === "scenario") {
        scenarioTab.classList.add("active");
        buttons[0].classList.add("active");
      } else {
        voiceTab.classList.add("active");
        buttons[1].classList.add("active");
      }
    }

    const scenarioSteps = {
      theft: [
        {
          title: "질문 1",
          question: "긴급신고 112입니다. 신고자분 무슨 일이 발생했나요?",
          hint: "위치와 상황을 함께 말하면 가장 좋아요.
          audio: "/audio/q1.mp3",
          feedbackGood: "좋아요. 위치와 상황을 함께 말하면 출동이 더 빨라집니다.",
          feedbackBad: "조금 아쉬워요. 먼저 현재 위치를 말하고, 어떤 일이 생겼는지 바로 알려주세요.",
          answers: [
            { text: "무안읍 편의점 앞인데요. 방금 가방을 빼앗는 걸 봤습니다.", good: true },
            { text: "그냥 좀 이상한 사람이 있는데요. 빨리 와주세요.", good: false }
          ]
        },
        {
          title: "질문 2",
          question: "범인은 어느 방향으로 갔나요? 옷차림도 보였나요?",
          hint: "이동 방향, 옷 색깔, 인원 수처럼 바로 보이는 정보만 짧게 말하면 됩니다.",
          audio: "/audio/q2.mp3",
          feedbackGood: "좋습니다. 방향과 옷차림은 현장 확인에 큰 도움이 됩니다.",
          feedbackBad: "괜찮아요. 잘 못 봤더라도 방향이나 대략적인 특징 하나만 말해도 도움이 됩니다.",
          answers: [
            { text: "버스정류장 쪽으로 도망갔고, 검은색 후드티를 입었습니다.", good: true },
            { text: "잘 모르겠고 그냥 빨리 잡아주세요.", good: false }
          ]
        },
        {
          title: "질문 3",
          question: "다친 사람이나 지금 위험한 상황이 있나요?",
          hint: "피해자 상태, 흉기 여부, 주변 위험 여부를 말하면 우선 대응에 도움이 됩니다.",
          audio: "/audio/q3.mp3",
          feedbackGood: "아주 좋아요. 피해자의 상태를 알려주면 현장 대응 순서를 빨리 정할 수 있습니다.",
          feedbackBad: "위험 여부를 꼭 말해보세요. 다친 사람, 흉기, 추가 위험이 있는지가 중요합니다.",
          answers: [
            { text: "피해자가 넘어져서 다친 것 같고, 빨리 확인이 필요합니다.", good: true },
            { text: "다른 사람한테 물어보시는게 좋을 것 같아요 저는 바빠서.", good: false }
          ]
        }
      ],

      phishing: [
        {
          title: "질문 1",
          question: "긴급신고 112입니다. 어떤 보이스피싱 의심 상황이신가요?",
          hint: "누가 어떤 기관을 사칭했는지 먼저 말해보세요.",
          audio: "/audio/p1.mp3",
          feedbackGood: "좋습니다. 사칭 기관과 상황을 먼저 말하면 판단이 빨라집니다.",
          feedbackBad: "조금 더 구체적으로 말해보세요. 경찰, 검찰, 금융기관 사칭인지 중요합니다.",
          answers: [
           { text: "검찰이라고 하면서 제 계좌가 범죄에 연루됐다고 전화가 왔습니다.", good: true },
           { text: "이상한 전화가 왔어요.", good: false }
         ]
       },
        {
          title: "질문 2",
          question: "상대방이 돈을 이체하라고 했거나 앱 설치를 요구했나요?",
          hint: "송금 요구, 원격제어 앱 설치 요구는 대표적인 피싱입니다.",
          audio: "/audio/p2.mp3",
          feedbackGood: "정확합니다. 돈 요구나 앱 설치 요구는 보이스피싱 핵심 수법입니다.",
          feedbackBad: "중요한 부분입니다. 돈이나 앱 설치 요구 여부를 꼭 알려주세요.",
          answers: [
           { text: "네, 안전계좌라면서 돈을 보내라고 했고 앱도 설치하라고 했습니다.", good: true },
           { text: "그건 잘 모르겠고 그냥 무서웠어요.", good: false }
         ]
       },
        {
          title: "질문 3",
          question: "이미 송금했거나 개인정보를 알려준 것이 있나요?",
         hint: "피해 여부를 확인해야 즉시 대응이 가능합니다.",
         audio: "/audio/p3.mp3",
         feedbackGood: "잘하셨습니다. 피해 여부 확인은 가장 중요한 단계입니다.",
         feedbackBad: "괜찮습니다. 송금 여부나 정보 제공 여부를 정확히 말하는 것이 중요합니다.",
        answers: [
        { text: "계좌번호를 알려줬고 일부 금액을 송금했습니다.", good: true },
            { text: "부모님께 비밀이라 아직은 말하기 어렵습니다.", good: false }
          ]
        }
      ]
    };

    let currentScenario = "theft";
    let currentStep = 0;
    let goodCount = 0;
    let currentAudio = "";

    const audioPlayer = document.getElementById("audioPlayer");

    function getCurrentSteps() {
      return scenarioSteps[currentScenario];
    }

    function changeScenario(type) {
      currentScenario = type;
      currentStep = 0;
      goodCount = 0;

      document.getElementById("scenarioTheftBtn").classList.remove("active");
      document.getElementById("scenarioPhishingBtn").classList.remove("active");

      if (type === "theft") {
        document.getElementById("scenarioTheftBtn").classList.add("active");
      } else {
        document.getElementById("scenarioPhishingBtn").classList.add("active");
      }

      document.getElementById("quizBox").style.display = "block";
      document.getElementById("hintBox").style.display = "block";
      document.getElementById("answerButtons").style.display = "grid";
      document.getElementById("waveRow").style.display = "flex";
      document.getElementById("resultBox").style.display = "none";
      document.getElementById("feedbackBox").style.display = "none";

      renderStep();
    }

    function playAudio(file) {
      currentAudio = file;
      audioPlayer.pause();
      audioPlayer.currentTime = 0;
      audioPlayer.src = file;
      audioPlayer.play().catch(() => {});
    }

    function replayCurrentAudio() {
      if (!currentAudio) return;
      playAudio(currentAudio);
    }

  function renderStep() {
  const steps = getCurrentSteps();
  const step = steps[currentStep];

  document.getElementById("callStatus").innerText = `112 연결됨 · ${currentStep + 1}/${steps.length}`;
  document.getElementById("questionTitle").innerText = step.title;
  document.getElementById("questionText").innerText = step.question;
  document.getElementById("hintText").innerText = step.hint;

  const answerBox = document.getElementById("answerButtons");
  const feedbackBox = document.getElementById("feedbackBox");

  feedbackBox.style.display = "none";
  feedbackBox.className = "feedback-box";
  feedbackBox.innerHTML = "";
  answerBox.innerHTML = "";

  step.answers.forEach((answer) => {
    const btn = document.createElement("button");
    btn.className = "answer-btn";
    btn.innerText = answer.text;
    btn.onclick = () => selectAnswer(answer.good);
    answerBox.appendChild(btn);
  });

  currentAudio = step.audio;
  audioPlayer.pause();
  audioPlayer.currentTime = 0;
}

    function selectAnswer(isGood) {
      const steps = getCurrentSteps();
      const step = steps[currentStep];
      const feedbackBox = document.getElementById("feedbackBox");
      feedbackBox.style.display = "block";

      if (isGood) {
        goodCount += 1;
        feedbackBox.classList.add("feedback-good");
        feedbackBox.innerText = `👍 ${step.feedbackGood}`;
      } else {
        feedbackBox.classList.add("feedback-bad");
        feedbackBox.innerText = `⚠️ ${step.feedbackBad}`;
      }

      document.querySelectorAll(".answer-btn").forEach((btn) => {
        btn.disabled = true;
        btn.style.opacity = "0.7";
      });

      setTimeout(() => {
        currentStep += 1;
        if (currentStep >= steps.length) {
          showResult();
        } else {
          renderStep();
        }
      }, 1400);
    }

    function showResult() {
      document.getElementById("quizBox").style.display = "none";
      document.getElementById("hintBox").style.display = "none";
      document.getElementById("answerButtons").style.display = "none";
      document.getElementById("feedbackBox").style.display = "none";
      document.getElementById("waveRow").style.display = "none";
      document.getElementById("callStatus").innerText = "112 연습 통화 종료";

      const resultText = document.getElementById("resultText");

      if (currentScenario === "phishing") {
        if (goodCount >= 2) {
          resultText.innerText = "잘하셨습니다. 보이스피싱 신고 시에는 사칭 내용, 금전 요구 여부, 송금 여부를 빠르게 알려주는 것이 중요합니다.";
        } else {
          resultText.innerText = "다시 연습해보세요. 보이스피싱은 누가 무엇을 요구했는지, 돈을 보냈는지, 앱 설치를 요구했는지를 구체적으로 말하는 것이 중요합니다.";
        }
      } else {
        if (goodCount >= 2) {
          resultText.innerText = "잘하셨습니다. 절도 신고 시에는 위치, 상황, 도주 방향, 피해자 상태를 차례대로 말하는 것이 중요합니다.";
        } else {
          resultText.innerText = "다시 연습해보세요. 절도 신고는 위치와 상황을 먼저 말하고, 방향과 위험 정도를 이어서 말하면 더 좋습니다.";
        }
      }

      document.getElementById("resultBox").style.display = "block";
      audioPlayer.pause();
    }

    function restartPractice() {
      currentStep = 0;
      goodCount = 0;
      document.getElementById("quizBox").style.display = "block";
      document.getElementById("hintBox").style.display = "block";
      document.getElementById("answerButtons").style.display = "grid";
      document.getElementById("waveRow").style.display = "flex";
      document.getElementById("resultBox").style.display = "none";
      renderStep();
      showTab("voice");
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function goHome() {
      window.location.href = "/";
    }

    renderStep();
  </script>
</body>
</html>
