<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>관리자 페이지</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials_header', { isAdmin: isAdmin }) %>

  <div class="container">
    <div class="white-card" style="margin-bottom:20px;">
      <h2 style="margin-top:0; color:#1565c0;">게시글 등록</h2>

      <% if (error) { %>
        <div class="notice-error" style="margin-bottom:12px;"><%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="notice-success" style="margin-bottom:12px;"><%= success %></div>
      <% } %>

      <form method="POST" action="/admin/posts" enctype="multipart/form-data" class="form-grid">
        <select name="category" required>
          <option value="">카테고리 선택</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.key %>"><%= c.name %></option>
          <% }) %>
        </select>

        <input type="text" name="title" placeholder="제목 입력" required>
        <textarea name="content" placeholder="내용 입력" required></textarea>

        <input type="file" name="media" accept="image/*,video/mp4,video/webm,video/ogg,video/quicktime">
        <div class="file-help">
          사진 또는 영상 파일 직접 업로드 가능<br>
          권장: 1분 이내 영상 / 최대 200MB (업로드 후 Cloudinary에 저장되며, 영상은 아이폰 호환 MP4로 변환)
        </div>

        <button type="submit" class="btn-primary">게시글 등록</button>
      </form>
    </div>

    <div class="white-card">
      <h2 style="margin-top:0; color:#1565c0;">등록된 게시글</h2>
      <% if (!posts.length) { %>
        <div>등록된 게시글이 없습니다.</div>
      <% } %>

      <% posts.forEach(post => { %>
        <div class="admin-post-row">
          <div>
            <div class="admin-post-title">[<%= categories.find(c => c.key === post.category)?.name || post.category %>] <%= post.title %></div>
            <div class="post-meta"><%= post.created_at %> <% if (post.media_type) { %> / <%= post.media_type %><% } %></div>
          </div>
          <div style="display:flex; gap:8px; flex-wrap:wrap;">
            <a class="btn-primary" style="display:inline-block; text-align:center;" href="/admin/posts/<%= post.id %>/edit">수정</a>
            <form method="POST" action="/admin/posts/<%= post.id %>/delete" onsubmit="return confirm('삭제하시겠습니까?')">
              <button class="btn-danger" type="submit">삭제</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

<% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
  <div class="white-card" style="margin-top:20px;">
    <h3 style="margin-top:0; color:#1565c0;">관리자 계정 추가</h3>
    <form method="POST" action="/admin/users" class="form-grid">
      <input type="text" name="username" placeholder="관리자 아이디 입력" required>
      <input type="text" name="display_name" placeholder="닉네임 입력 (예: 범죄예방)" required>
      <div class="file-help">
        기본 비밀번호는 <strong>무안서1!</strong> 입니다.
      </div>
      <button type="submit" class="btn-primary">관리자 추가</button>
    </form>
  </div>
<% } %>
  </div>
</body>
</html>

<div class="white-card" style="margin-top:20px;">
  <h3 style="margin-top:0; color:#1565c0;">비밀번호 변경</h3>
  <form method="POST" action="/admin/password" class="form-grid">
    <input type="password" name="current_password" placeholder="현재 비밀번호 입력" required>
    <input type="password" name="new_password" placeholder="새 비밀번호 입력" required>
    <input type="password" name="confirm_password" placeholder="새 비밀번호 확인" required>
    <button type="submit" class="btn-primary">비밀번호 변경</button>
  </form>
</div>

<% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin && typeof admins !== 'undefined') { %>
  <div class="white-card" style="margin-top:20px;">
    <h3 style="margin-top:0; color:#1565c0;">관리자 목록</h3>

    <% admins.forEach(a => { %>
      <div class="admin-post-row">
        <div>
          <div class="admin-post-title"><%= a.display_name %></div>
          <div class="post-meta">
            아이디: <%= a.username %> /
            권한: <%= a.role %> /
            상태: <%= a.is_active ? '활성' : '비활성' %>
          </div>
        </div>

   <% if (a.role !== 'superadmin') { %>
          <div style="display:flex; gap:8px; flex-wrap:wrap;">

            <!-- 닉네임 수정 -->
            <form method="POST" action="/admin/users/<%= a.id %>/update" style="display:flex; gap:6px;">
              <input type="text" name="display_name" value="<%= a.display_name %>" style="width:140px;">
              <button type="submit" class="btn-primary">수정</button>
            </form>

            <!-- 비밀번호 초기화 -->
            <form method="POST" action="/admin/users/<%= a.id %>/password-reset"
                  onsubmit="return confirm('비밀번호를 초기화하시겠습니까?');">
              <button type="submit" class="btn-danger">초기화</button>
            </form>

            <!-- 비활성화 -->
            <form method="POST" action="/admin/users/<%= a.id %>/toggle-active"
                  onsubmit="return confirm('계정 상태를 변경하시겠습니까?');">
              <button type="submit" class="btn-primary">
                <%= a.is_active ? '비활성화' : '재활성화' %>
              </button>
            </form>

          </div>
        <% } %>
      </div>
    <% }) %>
  </div>
<% } %>
